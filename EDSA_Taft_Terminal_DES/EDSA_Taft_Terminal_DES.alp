			<DestroyCode><![CDATA[javax.swing.JOptionPane.showMessageDialog(null,
    "===== SIMULATION RESULTS =====\n" +
    "Period: 5:00 PM - 8:00 PM\n\n" +
    "Avg Wait Time:       " + String.format("%.2f", waitData.mean()) + " min\n" +
    "Peak Queue Length:   " + peakQueueLength + " passengers\n" +
    "Avg Queue Length:    " + String.format("%.2f", passengerQueue.statsSize.mean()) + " passengers\n" +
    "Total Passengers:    " + totalPassengersServed + "\n" +
    "Vans Dispatched:     " + totalVansDispatched + "\n" +
    "Throughput:          " + String.format("%.1f", totalPassengersServed / 3.0) + " pax/hr\n" +
    "Van Utilization:     " + String.format("%.1f", loadingBayResource.utilization() * 100) + "%\n" +
    "Bay Idle Time:       " + String.format("%.1f", (1 - loadingBayResource.utilization()) * 100) + "%"
);]]></DestroyCode>
